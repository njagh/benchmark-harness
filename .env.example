# OpenAI-compatible local endpoint
OPENAI_BASE_URL=http://spark-e287.local:4000/v1
OPENAI_API_KEY=not-needed

# HuggingFace cache — all eval data loaded from local pinned files.
# Never stream from HuggingFace during measured runs.
# See STORAGE_PLAN.md for dataset layout.
HF_HOME=/mnt/datasets-big/hf-cache
HF_DATASETS_CACHE=/mnt/datasets-big/hf-cache/datasets
HF_HUB_CACHE=/mnt/datasets-big/hf-cache/hub
