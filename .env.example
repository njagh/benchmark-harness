# OpenAI-compatible local endpoint (adjust to your model server)
OPENAI_BASE_URL=http://localhost:4000/v1
OPENAI_API_KEY=not-needed

# HuggingFace cache — all eval data loaded from local pinned files.
# Never stream from HuggingFace during measured runs.
# See STORAGE_PLAN.md for dataset layout.
HF_HOME=/path/to/hf-cache
HF_DATASETS_CACHE=/path/to/hf-cache/datasets
HF_HUB_CACHE=/path/to/hf-cache/hub
